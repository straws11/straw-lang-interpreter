int[] a = [91, 123, 123, 342, 12, 421]
int i = 0
while i < 6 {
    print(int_to_str(a[i]))
    i = i + 1
}

fn reverse(int[] nums) -> int[] {
    int[] new_nums = [-1, -1, -1, -1, -1, -1]
    for (int i = 0; i < new_nums.length; i = i + 1) {
        new_nums[i] = nums[6 - i - 1]
    }
    return new_nums
}

int[] b = reverse(a)

